    }

    for partner_code, partner_name in COUNTRIES.items():
        if base_code == partner_code:
            row[partner_name] = 0
            continue

        count = get_paper_count(
            query=tech_query,
            base_country=base_code,
            partner_country=partner_code
        )

        row[partner_name] = count

        time.sleep(6)

    results.append(row)


